// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ##### APPEARANCE #####
  "sticky_scroll": {
    "enabled": true
  },
  "icon_theme": "Bearded Icon Theme",
  "minimum_contrast_for_highlights": 40.0,
  "ui_font_size": 13,
  "buffer_font_family": "CommitMono",
  "buffer_font_size": 13,
  "theme": {
    "mode": "system",
    "light": "Base16 One Light",
    "dark": "Base16 Default Dark",
  },
  "theme_overrides": {
    "Base16 One Light": {
      "element.selected": "#c1840180",
      "element.hover": "#c184013f",
      "ghost_element.selected": "#c1840180",
      "search.match_background": "#c184013f",
      "search.active_match_background": "#c1840180",
      "editor.document_highlight.read_background": "#c184013f",
      "editor.document_highlight.write_background": "#c1840180",
      "element.selection_background": "#c7403a83",
    },
  },
  // "experimental.theme_overrides": {
  //   "editor.document_highlight.read_background": "#59585A",
  // },
  "scrollbar": {
    "axes": {
      // disable horizontal scrollbar
      "horizontal": false,
    },
  },
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.8,
  },
  "tabs": {
    "git_status": true,
  },
  "project_panel": {
    "default_width": 240,
    "bold_folder_labels": true,
    "entry_spacing": "standard",
    "indent_size": 15,
  },
  "outline_panel": {
    "default_width": 240,
    "indent_size": 15,
  },
  "gutter": {
    "min_line_number_digits": 3,
  },

  // ##### EDITOR #####
  "vim_mode": true,
  "base_keymap": "VSCode",
  "hover_popover_delay": 1000,
  "use_smartcase_search": true,
  "always_treat_brackets_as_autoclosed": true,
  "vertical_scroll_margin": 5,

  // ##### LANGUAGES #####
  "languages": {
    "Elixir": {
      "formatter": {
        "external": {
          "command": "mix",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
      "format_on_save": "on",
      "language_servers": [
        "!expert",
        "elixir-ls",
        "!next-ls",
        "!lexical",
        "...",
      ],
    },
    "HEEX": {
      "language_servers": [
        "!expert",
        "elixir-ls",
        "!next-ls",
        "!lexical",
        "...",
      ],
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
  },
  "lsp_highlight_debounce": 500,
  "lsp": {
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore",
          },
        },
      },
    },
  },
  "file_types": {
    "GitHub Actions": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
  },

  // ##### AI #####
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-5-latest",
    },
    "favorite_models": [
      {
        "provider": "anthropic",
        "model": "claude-opus-4-5-latest",
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-5-latest",
      },
    ],
    "model_parameters": [],
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "agent_servers": {
    "claude": {
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "~/.claude-work/local/claude",
        "CLAUDE_CONFIG_DIR": "~/.claude-work",
      },
    },
  },
}
